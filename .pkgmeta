package-as: WowUkrainizer

embedded-libraries:
  - ace3
  - libstub
  - libdatabroker-1-1

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .releaserc
  - .env
  - .secrets
  - .actrc
  - .vscode
  - .git
  - .github
  - run_act.bat
  - screenshots
  - cvars.dump
  - package.json
  - package-lock.json
  - release.sh
  - DevTools
  - RawData
  - docs
  - types
